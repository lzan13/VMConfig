### set custom shell path
export VMSHELL="$HOME/.vmconfig/Linux"
export PATH=$PATH:$VMSHELL/bin

# ### set jdk path
# export JAVA_HOME="/$HOME/Develop/Tools/JetBrains/Applications/Android\ Studio.app/Contents/jbr/Contents/Home"
# export JAVA_HOME="/$HOME/Develop/SDK/Java/Jdk1.8/Contents/Home"
# export JAVA_HOME="/$HOME/Develop/SDK/Java/Jdk17/Contents/Home"
export JAVA_HOME="$HOME/Develop/SDK/Java/Jdk21"
export PATH=$PATH:$JAVA_HOME/bin


### set Android sdk path
export ANDROID_HOME="$HOME/Develop/SDK/Android"
export PATH=$PATH:$ANDROID_HOME:$ANDROID_HOME/platform-tools:$ANDROID_HOME/tools:$ANDROID_HOME/build-tools/36.1.0


### set Android ndk path
export ANDROID_NDK="$HOME/Develop/SDK/Android/ndk-bundle"
export PATH=$PATH:$ANDROID_NDK


### nvm path
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

### repo git source
export REPO_URL="https://mirrors.tuna.tsinghua.edu.cn/git/git-repo/"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end